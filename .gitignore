*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg

# --- Environment ---
.env
.env.local
.env.production
.venv/
venv/
env/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Database ---
*.db
*.sqlite3

# --- Docker ---
docker-compose.override.yml

# --- Node / Frontend ---
node_modules/
.next/
out/
.vercel/
*.tsbuildinfo

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs ---
*.log
logs/

# --- Coverage ---
htmlcov/
.coverage
coverage.xml

# --- Alembic ---
# NÃO ignorar alembic/versions/ — migrations devem ser versionadas
