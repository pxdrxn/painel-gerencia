# ============================================
# S.O.S Crédito — Painel de Gerência
# Variáveis de Ambiente
# ============================================
# Copie para .env e preencha os valores reais

# --- App ---
APP_NAME="S.O.S Crédito — Painel de Gerência"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
# Desenvolvimento local (Docker):
DATABASE_URL=postgresql+asyncpg://sos_credito:dev_password@localhost:5432/painel_gerencia
# Neon PostgreSQL (produção):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/painel_gerencia?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# --- JWT ---
# IMPORTANTE: Gere uma chave segura usando: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-USE-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- URLs ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
